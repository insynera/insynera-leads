# ─────────────────────────────────────────────
# INSYNERA Lead System — Environment Variables
# ─────────────────────────────────────────────
# 1. Copy this file and rename it to: .env
# 2. Paste your Companies House API key below
# 3. Never commit .env to git

# Your Companies House API key
# Get one free at: https://developer-specs.company-information.service.gov.uk/
CH_API_KEY=YOUR_API_KEY_HERE

# Port the server runs on (3000 is default, change if needed)
PORT=3000

# Your agency name (appears in email templates)
AGENCY_NAME=INSYNERA

# Your name (appears in email sign-offs)
YOUR_NAME=Your Name

# Your website
AGENCY_URL=https://insynera.com
